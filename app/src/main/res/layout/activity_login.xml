<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#0A0A12">


    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0A0F"
        android:padding="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back_white"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin Login"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:padding="28dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_admin"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:padding="5dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@drawable/my_img"
            app:shapeAppearanceOverlay="@style/circleImage"
            app:strokeColor="#60A5FA"
            android:layout_marginBottom="40dp"
            app:strokeWidth="2dp" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter  phone number to receive OTP"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="36dp" />

        <LinearLayout
            android:id="@+id/layout_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_dark"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+91"
                    android:textColor="#60A5FA"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="14dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#334155" />

                <EditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="6369636340"
                    android:textColor="#F1F5F9"
                    android:textColorHint="#475569"
                    android:background="@null"
                    android:paddingHorizontal="14dp"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:singleLine="true" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_otp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter OTP"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_otp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="6-digit OTP"
                android:textColor="#F1F5F9"
                android:textColorHint="#475569"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="16dp"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:singleLine="true"
                android:gravity="center"
                android:textSize="22sp"
                android:letterSpacing="0.3"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_resend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resend OTP"
                    android:textColor="#60A5FA"
                    android:textSize="13sp"
                    android:alpha="0.4"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Send OTP Button -->
        <LinearLayout
            android:id="@+id/btn_send_otp"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_blue"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_send_btn_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEND OTP"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_verify_otp"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_download"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFY OTP ✓"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Only the registered admin number can access the panel."
            android:textColor="#334155"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐"
                android:textSize="48sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADMIN LOGIN"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Portfolio Control Panel"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginBottom="36dp" />

            <!-- Username -->
            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Username"
                android:textColor="#F1F5F9"
                android:textColorHint="#475569"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginBottom="14dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Password"
                android:textColor="#F1F5F9"
                android:textColorHint="#475569"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="LOGIN"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:background="@drawable/bg_btn_blue"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="#3B82F6"
                android:layout_marginTop="8dp"/>

            <ProgressBar
                android:id="@+id/progress_bar1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
