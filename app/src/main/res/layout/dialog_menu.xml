<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/menu_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close_pink"
            android:layout_marginEnd="16dp"
            android:padding="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGESH S"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <TextView
        android:id="@+id/nav_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textColor="#7C9ED9"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"

        android:clickable="true"
        android:focusable="true" />

    <View
        android:id="@+id/line_home"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/nav_about"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:background="@drawable/menu_item_bg"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_about"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/nav_resume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resume"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_resume"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/nav_portfolio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Portfolio"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_portfolio"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/nav_skills"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skills"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_skills"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />
    <TextView
        android:id="@+id/nav_edu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Education"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_edu"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />


    <TextView
        android:id="@+id/nav_contact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contact"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:paddingVertical="14dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />
    <View
        android:id="@+id/line_contact"
        android:layout_width="50dp"
        android:layout_height="2dp"
        android:background="#7C9ED9"
        android:visibility="gone"
        android:layout_marginBottom="6dp" />


</LinearLayout>